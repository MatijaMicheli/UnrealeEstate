{
  "inlineFold.regexes": [
    {
      "regex": "<svg[\\s\\S]*?<\\/svg>",
      "regexFlags": "g",
      "regexGroup": 0
    },
    {
      "regex": "<svg(\\s*.*?\\s*)<\\/svg>",
      "regexFlags": "gs",
      "regexGroup": 1
    }
  ],
  "inlineFold.unfoldedOpacity": 0.3,
  "inlineFold.maskChar": "…",
  "inlineFold.maskCss": "color:#888; font-style: italic;",
  "inlineFold.supportedLanguages": [
    "html",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "inlineFold.unfoldOnLineSelect": true,
  "inlineFold.autoFoldOnOpen": true
}